<?xml version="1.0"?>

<!--
  This is a very simple config file with many options missing. For a complete
  set of options with comments, see docs/rc.xml.all
-->

<labwc_config>

  <desktops number="4" />

  <!-- Disable window decorations -->
  <windowRules>
    <windowRule identifier="*">
      <action name="SetDecorations" decorations="border" />
    </windowRule>
  </windowRules>

  <windowSwitcher preview="yes" outlines="yes">
    <osd show="yes" style="classic" />
    <fields>
      <field content="title" width="100%" />
    </fields>
  </windowSwitcher>

  <theme>
    <name></name>
    <cornerRadius>8</cornerRadius>
    <font name="Go Mono" size="16" />
  </theme>

  <keyboard>
    <default />
    <!-- Tab between windows -->
    <keybind key="W-Tab">
      <action name="NextWindow" />
    </keybind>
    <keybind key="W-S-Tab">
      <action name="PreviousWindow" />
    </keybind>
    <!-- Open launcher -->
    <keybind key="W-Space">
      <action name="Execute" command="rofi -show drun -display-drun 'open' -font 'Go Mono 16'" />
    </keybind>
    <!-- Open quick menu -->
    <keybind key="W-m">
      <action name="Execute" command="~/.scripts/menu.sh" />
    </keybind>
    <!-- Use a different terminal emulator -->
    <keybind key="W-Return">
      <action name="Execute" command="alacritty" />
    </keybind>
    <keybind key="W-1">
      <action name="GoToDesktop" to="1" />
    </keybind>
    <keybind key="W-2">
      <action name="GoToDesktop" to="2" />
    </keybind>
    <keybind key="W-3">
      <action name="GoToDesktop" to="3" />
    </keybind>
    <keybind key="W-4">
      <action name="GoToDesktop" to="4" />
    </keybind>
    <keybind key="W-f">
      <action name="ToggleFullscreen" />
    </keybind>
    <!--
      Remove a previously defined keybind
      A shorter alternative is <keybind key="W-F4" />
    -->
    <keybind key="W-F4">
      <action name="None" />
    </keybind>
  </keyboard>

  <mouse>
    <default />
    <!-- Show a custom menu on desktop right click -->
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu" menu="some-custom-menu" />
      </mousebind>
    </context>

    <context name="Frame">
      <mousebind button="W-Left" action="Press">
        <action name="Focus" />
        <action name="Raise" />
      </mousebind>
      <mousebind button="W-Left" action="Drag">
        <action name="Move" />
      </mousebind>
      <mousebind button="W-Right" action="Press">
        <action name="Focus" />
        <action name="Raise" />
      </mousebind>
      <mousebind button="W-Right" action="Drag">
        <action name="Resize" />
      </mousebind>
    </context>
  </mouse>

  <libinput>
    <device category="default">
      <naturalScroll>no</naturalScroll>
    </device>
  </libinput>

</labwc_config>
