# Include container name in prompt if in a container.
if [ -f /run/.containerenv ]; then
	container_name=$(sed -n 's/^name="\(.*\)"/\1/p' /run/.containerenv)
	PS1='[${container_name}] ${PWD##*/} $ '
else
	PS1='${PWD##*/} $ '
fi

PATH=$PATH:~/.local/bin

alias ls='ls -p'
alias weather='curl wttr.in/?0Tq'

# Binaries located in toolbx containers.
alias kew='toolbox run --container ubuntu-toolbox-24.04 kew'
