#!/usr/bin/env sh

FONT_NAME="Go Mono"

{{- if eq .chezmoi.hostname "spock" }}
FONT_SIZE=24
{{- else }}
FONT_SIZE=16
{{- end }}

# Get removable block devices.
# Uses --pairs mode to avoid column shifting when fields are empty.
build_drive_list() {
  /bin/lsblk -Po NAME,TYPE,SIZE,LABEL,MOUNTPOINT,TRAN | awk '
    function unquote(s,   v) {
      match(s, /="([^"]*)"/, v)
      return v[1]
    }
    {
      name  = unquote($1)
      type  = unquote($2)
      size  = unquote($3)
      label = unquote($4)
      mount = unquote($5)
      tran  = unquote($6)
    }
    type == "disk" { current_tran = tran }
    (type == "disk" || type == "part") {
      t = (tran != "" ? tran : current_tran)
      if (t != "usb") next

      short = name; sub(".*/", "", short)
      lbl    = (label != "" ? label : "unlabeled")
      status = (mount != "" ? "mounted: " mount : "not mounted")
      print short " (" lbl ", " size ", " status ")"
    }
  '
}

DRIVES=$(build_drive_list)

if [ -z "$DRIVES" ]; then
  rofi -e "No removable drives detected." -font "$FONT_NAME $FONT_SIZE"
  exit 0
fi

# First menu: pick a drive
SELECTED_DRIVE=$(echo "$DRIVES" | rofi -dmenu -i -p "select drive" \
  -disable-history -font "$FONT_NAME $FONT_SIZE")

[ -z "$SELECTED_DRIVE" ] && exit 0

# Extract the short device name (e.g. "sdb") from the selected line
DEV_SHORT=$(echo "$SELECTED_DRIVE" | awk '{print $1}')
DEV="/dev/$DEV_SHORT"

# Check current mount status
MOUNTPOINT=$(lsblk -rno MOUNTPOINT "$DEV" 2>/dev/null)

# Build action menu based on current state
if [ -n "$MOUNTPOINT" ]; then
  ACTIONS="Unmount|Safely remove"
else
  ACTIONS="Mount|Safely remove"
fi

ACTION=$(echo "$ACTIONS" | rofi -sep "|" -dmenu -i \
  -p "$DEV_SHORT" -lines 2 -disable-history -font "$FONT_NAME $FONT_SIZE")

[ -z "$ACTION" ] && exit 0

case "$ACTION" in
  Mount)
    RESULT=$(udisksctl mount -b "$DEV" 2>&1)
    rofi -e "$RESULT" -font "$FONT_NAME $FONT_SIZE"
    ;;
  Unmount)
    RESULT=$(udisksctl unmount -b "$DEV" 2>&1)
    rofi -e "$RESULT" -font "$FONT_NAME $FONT_SIZE"
    ;;
  "Safely remove")
    if [ -n "$MOUNTPOINT" ]; then
      udisksctl unmount -b "$DEV" 2>&1
    fi
    PARENT=$(lsblk -rno PKNAME "$DEV" 2>/dev/null)
    if [ -n "$PARENT" ]; then
      RESULT=$(udisksctl power-off -b "/dev/$PARENT" 2>&1)
    else
      RESULT=$(udisksctl power-off -b "$DEV" 2>&1)
    fi
    rofi -e "${RESULT:-Drive safely removed.}" -font "$FONT_NAME $FONT_SIZE"
    ;;
esac
